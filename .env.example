# bisque-booking environment variables
# Copy to .env and fill in your values

# Core
DEBUG=false
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://bisque:bisque@db:5432/bisque_booking
DB_PASSWORD=bisque

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Google OAuth — get from Google Cloud Console
# Enable: Google Calendar API, Google People API
# Add redirect URI: {BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Fernet encryption key for stored OAuth tokens
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# SMTP — works with Gmail app passwords, Postmark, Mailgun, etc.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@your-domain.com
