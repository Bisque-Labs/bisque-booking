# ─── Vercel Environment Variables Reference ───────────────────────────────────
# Copy these into: Vercel Dashboard → Project → Settings → Environment Variables
# Required vars are marked [REQUIRED]. Others have safe defaults.

# ─── Core ─────────────────────────────────────────────────────────────────────
APP_NAME=bisque-booking                        # Optional display name
BASE_URL=https://your-project.vercel.app       # [REQUIRED] Your Vercel deployment URL
DEBUG=false                                    # Set to true for verbose logs

# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Create a free database at https://neon.tech
# Copy the "Connection string" from the Neon dashboard (pooled connection URL).
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# [REQUIRED]

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-min-32-chars-random!!     # [REQUIRED] JWT signing key (≥ 32 chars)
ENCRYPTION_KEY=                                # AES-256 key for Google OAuth tokens (optional)

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-project.vercel.app/auth/google/callback

# ─── SMTP Email ───────────────────────────────────────────────────────────────
# Leave blank to use the no-op provider (emails logged, not sent).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
FROM_EMAIL=noreply@your-domain.com

# ─── Webhooks (optional) ──────────────────────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_SECRET=

# ─── Cron Job Protection ──────────────────────────────────────────────────────
# Vercel automatically sets CRON_SECRET for you — no action needed.
# To call /api/cron/send-reminders manually: Authorization: Bearer $CRON_SECRET
# CRON_SECRET=  (set by Vercel automatically)

# ─── Migration Endpoint Protection ────────────────────────────────────────────
# Protect POST /api/migrate with a secret token.
# Generate with: openssl rand -hex 32
MIGRATE_SECRET=your-random-secret-here
