# bisque-booking environment variables
# Copy to .env.local for local development

# Admin password for /admin/* routes
ADMIN_PASSWORD=change-me

# Secret for signing session JWTs (at least 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string-here

# Database path (defaults to ./data/bookings.db)
# DATABASE_PATH=/path/to/bookings.db

# Optional: Kissinger CRM integration
# When set, bookings will be synced to Kissinger as Contacts + Interactions
# KISSINGER_GRAPHQL_URL=http://localhost:4000/graphql

# Optional: Email sending
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_...
# EMAIL_FROM=booking@yourdomain.com

# Optional: Cron secret (for /api/booking/cron/reminders)
# CRON_SECRET=change-me

# Optional: Google Calendar OAuth
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
