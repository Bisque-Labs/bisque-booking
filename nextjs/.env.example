# bisque-booking environment variables
# ──────────────────────────────────────────────────────────────────────────────
# DOCKER COMPOSE: copy this file to .env at the repo root (next to docker-compose.yml)
#   cp nextjs/.env.example .env
#
# LOCAL DEV: copy to nextjs/.env.local
#   cp nextjs/.env.example nextjs/.env.local
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Admin password for /admin/* routes
ADMIN_PASSWORD=change-me

# Secret for signing session JWTs — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string-here

# From address for all outgoing emails
HOST_EMAIL=you@example.com

# Public URL of the deployment (used in email links and Google OAuth redirect)
BASE_URL=https://booking.yourdomain.com

# Bearer token for POST /api/cron/reminders — generate with: openssl rand -hex 32
CRON_SECRET=change-me-to-a-long-random-string-here

# ── SQLite ────────────────────────────────────────────────────────────────────

# Path to the SQLite database file.
# Docker Compose: use the path inside the container (volume mount at /app/data)
DATABASE_PATH=/app/data/bookings.db

# Local dev: uncomment and adjust as needed
# DATABASE_PATH=./data/bookings.db

# ── Email — pick one provider ─────────────────────────────────────────────────

EMAIL_PROVIDER=resend

# Option 1: Resend (https://resend.com — recommended, free tier available)
RESEND_API_KEY=

# Option 2: SMTP (Gmail, Postmark, Mailgun, etc.)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password

# ── Optional: Google Calendar ─────────────────────────────────────────────────
# Enables busy-time sync so booked slots are hidden from the booking page.
# Create OAuth 2.0 credentials in Google Cloud Console, then add:
#   {BASE_URL}/api/auth/google/callback
# as an authorized redirect URI.

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://booking.yourdomain.com/api/auth/google/callback

# ── Optional: Kissinger CRM sync ──────────────────────────────────────────────
# Upserts a Contact + Interaction in Kissinger on each confirmed booking.
# Leave unset to disable.

# KISSINGER_GRAPHQL_URL=http://kissinger:4000/graphql
