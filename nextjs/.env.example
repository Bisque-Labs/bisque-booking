# bisque-booking environment variables
# Copy to .env.local for local development

# ── Required ──────────────────────────────────────────────────────────────────

# Admin password for /admin/* routes
ADMIN_PASSWORD=change-me

# Secret for signing session JWTs (at least 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string-here

# ── Optional: Database ────────────────────────────────────────────────────────

# SQLite file path (defaults to ./data/bookings.db)
# DATABASE_PATH=/path/to/bookings.db

# ── Optional: Email ───────────────────────────────────────────────────────────

# Public URL of the deployment (used in email links)
# BASE_URL=https://booking.example.com

# From address for all outgoing emails
# EMAIL_FROM=booking@example.com

# Provider 1: Resend (https://resend.com)
# RESEND_API_KEY=re_...

# Provider 2: SMTP (Gmail, Postmark, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password

# ── Optional: Cron ────────────────────────────────────────────────────────────

# Bearer token for POST /api/cron/reminders (Vercel Cron sets this automatically)
# CRON_SECRET=change-me

# ── Optional: Google Calendar ────────────────────────────────────────────────

# Enables Google Calendar busy-time sync for slot filtering.
# Create OAuth 2.0 credentials in Google Cloud Console.
# Add {BASE_URL}/api/auth/google/callback as an authorized redirect URI.
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# ── Optional: Kissinger CRM ───────────────────────────────────────────────────

# Enables Kissinger CRM sync (upsert Contact + Interaction on booking).
# KISSINGER_GRAPHQL_URL=http://localhost:4000/graphql
